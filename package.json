{
  "name": "fast-text-censor",
  "version": "1.0.2",
  "description": "Fast text censor using Aho-Corasick in Rust",
  "main": "lib.js",
  "types": "lib.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/aldinaufal21/fast-text-censor.git"
  },
  "files": [
    "lib.js",
    "lib.d.ts",
    "censor.js",
    "index.js",
    "index.d.ts",
    "list/*.txt",
    "*.node"
  ],
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "echo \"No tests specified\""
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.3"
  },
  "napi": {
    "name": "fast-text-censor",
    "triples": {
      "defaults": true,
      "additional": []
    }
  },
  "optionalDependencies": {
    "fast-text-censor-win32-x64-msvc": "1.0.0",
    "fast-text-censor-darwin-x64": "1.0.0",
    "fast-text-censor-linux-x64-gnu": "1.0.0"
  }
}